<% if (!isHostPage) { %>

<form action="/favourites" method="POST" class="mt-3">
  <input type="hidden" name="id" value="<%= home._id %>">

  <button
    type="submit"
    class="w-full flex justify-center items-center gap-2 bg-gradient-to-r from-emerald-500 to-cyan-500 text-white font-medium px-4 py-2 rounded-xl shadow hover:shadow-lg hover:scale-[1.02] transition-all duration-300"
  >
    💚 Add to Favourite
  </button>
</form>

<% } %>