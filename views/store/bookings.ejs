<%- include('../partials/head') %>
  </head>

  <body class="bg-slate-100 min-h-screen">

    <%- include('../partials/nav') %>
      <%- include('../partials/flash') %>

        <main class="max-w-6xl mx-auto px-4 py-10">

          <!-- Header -->
          <section class="bg-white rounded-3xl shadow-2xl overflow-hidden">

            <div class="bg-gradient-to-r from-emerald-500 to-cyan-600 px-8 py-8 text-white">

              <div class="flex flex-col sm:flex-row items-center gap-4">

                <div class="bg-white/15 backdrop-blur-md p-3 rounded-2xl border border-white/20 shadow-lg">
                  <img src="/images/logo.png" alt="HomeSpace Logo" class="w-14 h-14 object-contain">
                </div>

                <div>
                  <h2 class="text-3xl sm:text-5xl font-bold">
                    My Bookings
                  </h2>

                  <p class="mt-2 text-sm sm:text-base text-white/90">
                    View and manage your reserved stays on HomeSpace
                  </p>
                </div>

              </div>

            </div>

          </section>

          <!-- Booking List -->
          <div class="mt-8">

            <% if (bookings.length===0) { %>

              <!-- Empty State -->
              <section class="bg-white rounded-3xl shadow-xl px-8 py-16 text-center">

                <img src="/images/logo.png" alt="No Bookings" class="w-24 h-24 mx-auto mb-6 opacity-80">

                <h3 class="text-3xl font-bold text-slate-800 mb-3">
                  No Bookings Yet
                </h3>

                <p class="text-slate-500 text-lg mb-8">
                  Your future trips will appear here once you book a home.
                </p>

                <a href="/homes"
                  class="inline-block bg-gradient-to-r from-emerald-500 to-cyan-600 text-white px-8 py-3 rounded-xl font-semibold shadow-lg hover:scale-105 transition duration-300">
                  Explore Homes
                </a>

              </section>

              <% } else { %>

                <div class="space-y-8">

                  <% bookings.forEach(booking=> { %>

                    <div class="bg-white rounded-3xl shadow-xl overflow-hidden">

                      <div class="grid grid-cols-1 md:grid-cols-3">

                        <!-- Image -->
                        <div>
                          <img src="<%= booking.homeId.photo %>" alt="<%= booking.homeId.houseName %>"
                            class="w-full h-72 object-cover">
                        </div>

                        <!-- Details -->
                        <div class="md:col-span-2 p-8">

                          <div class="flex justify-between items-start flex-wrap gap-4">

                            <div>

                              <h2 class="text-3xl font-bold text-slate-800">
                                <%= booking.homeId.houseName %>
                              </h2>

                              <p class="mt-2 text-slate-500 text-lg">
                                📍 <%= booking.homeId.location %>
                              </p>

                            </div>

                            <div class="flex flex-col items-end gap-2">

                              <% if (booking.status==="Pending" ) { %>

                                <span class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full font-semibold">
                                  Pending
                                </span>

                                <% } else if (booking.status==="Confirmed" ) { %>

                                  <span class="bg-green-100 text-green-700 px-4 py-2 rounded-full font-semibold">
                                    Confirmed
                                  </span>

                                  <% } else if (booking.status==="Rejected" ) { %>

                                    <span class="bg-red-100 text-red-700 px-4 py-2 rounded-full font-semibold">
                                      Rejected
                                    </span>

                                    <% } else { %>

                                      <span class="bg-gray-100 text-gray-700 px-4 py-2 rounded-full font-semibold">
                                        Cancelled
                                      </span>

                                      <% } %>

                                        <span class="text-sm text-slate-500 font-medium">
                                          <%= booking.timelineStatus %>
                                        </span>

                            </div>
                          </div>

                          <div class="mt-6 grid sm:grid-cols-2 gap-5">

                            <div class="bg-slate-100 rounded-xl p-4">

                              <h4 class="font-semibold text-slate-700">
                                Stay Summary
                              </h4>

                              <div class="mt-3 space-y-2">

                                <p>
                                  📅
                                  <strong>Check In:</strong>

                                  <%= new Date(booking.checkIn).toLocaleDateString("en-IN") %>
                                </p>

                                <p>
                                  📅
                                  <strong>Check Out:</strong>

                                  <%= new Date(booking.checkOut).toLocaleDateString("en-IN") %>
                                </p>

                                <p>
                                  🌙
                                  <strong>Nights:</strong>

                                  <%= booking.nights %>
                                </p>

                                <p>
                                  👥
                                  <strong>Guests:</strong>

                                  <%= booking.guests %>
                                </p>

                              </div>

                            </div>

                            <div class="bg-slate-100 rounded-xl p-4">

                              <h4 class="font-semibold text-slate-700">
                                Payment Summary
                              </h4>

                              <div class="mt-3 space-y-2">

                                <p>

                                  💰
                                  <strong>Total Paid:</strong>

                                  <span class="text-emerald-600 font-bold">

                                    ₹<%= booking.totalPrice.toLocaleString("en-IN") %>

                                  </span>

                                </p>

                                <p>

                                  📝
                                  <strong>Booked On:</strong>

                                  <%= new Date(booking.bookingDate).toLocaleDateString("en-IN") %>

                                </p>

                                <p>

                                  💳
                                  <strong>Payment Status:</strong>

                                  <% if (booking.paymentStatus==="Paid" ) { %>

                                    <span class="text-green-600 font-bold">
                                      ✅ Paid
                                    </span>

                                    <% } else { %>

                                      <span class="text-red-600 font-bold">
                                        ❌ Pending
                                      </span>

                                      <% } %>

                                </p>

                                <% if (booking.paymentId) { %>

                                  <p class="break-all">

                                    🆔
                                    <strong>Payment ID:</strong>

                                    <span class="text-slate-600 text-sm">

                                      <%= booking.paymentId %>

                                    </span>

                                  </p>

                                  <% } %>

                                    <% if (booking.orderId) { %>

                                      <p class="break-all">

                                        📦
                                        <strong>Order ID:</strong>

                                        <span class="text-slate-600 text-sm">

                                          <%= booking.orderId %>

                                        </span>

                                      </p>

                                      <% } %>

                              </div>

                            </div>

                          </div>

                          <div class="mt-8 flex gap-4">

                            <% if ( booking.status==="Pending" || booking.status==="Confirmed" ) { %>

                              <form action="/bookings/<%= booking._id %>/cancel?_method=PATCH" method="POST">

                                <button class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-xl transition">
                                  Cancel Booking
                                </button>

                                <% if (booking.invoiceFile) { %>

                                  <a href="/invoices/<%= booking.invoiceFile %>" target="_blank"
                                    class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-xl transition">
                                    📄 Download Invoice
                                  </a>

                                  <% } %>

                              </form>

                              <% } %>

                          </div>

                        </div>

                      </div>

                    </div>

                    <% }) %>

                </div>

                <% } %>

          </div>

        </main>

  </body>

  </html>