<%- include('../partials/head') %>
</head>

<body class="bg-slate-100 min-h-screen">

  <%- include('../partials/nav') %>

  <main class="max-w-7xl mx-auto px-4 py-8">

    <!-- Main Card -->
    <section class="bg-white rounded-3xl shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="bg-gradient-to-r from-emerald-500 to-cyan-600 px-8 py-6 text-white">

        <div class="flex flex-col sm:flex-row items-center gap-4">

          <!-- Logo -->
          <div class="bg-white/15 backdrop-blur-md p-3 rounded-2xl border border-white/20 shadow-lg">
            <img 
              src="/images/logo.png"
              alt="HomeSpace Logo"
              class="w-14 h-14 object-contain"
            >
          </div>

          <!-- Title -->
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold">
              Details of <%= home.houseName %>
            </h2>

            <p class="mt-2 text-sm text-white/90">
              Explore this premium stay on HomeSpace
            </p>
          </div>

        </div>

      </div>

      <!-- Content -->
      <div class="p-8 grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- Left Image -->
        <div class="rounded-3xl overflow-hidden shadow-lg border border-slate-200">
          <img 
            src="<%= home.photo %>" 
            alt="<%= home.houseName %>" 
            class="w-full h-full min-h-[420px] object-cover hover:scale-105 transition duration-500"
          >
        </div>

        <!-- Right Details -->
        <div class="space-y-6">

          <!-- House Name -->
          <div>
            <h3 class="text-3xl font-bold text-slate-800">
              <%= home.houseName %>
            </h3>

            <p class="text-slate-500 mt-1">
              📍 <%= home.location %>
            </p>
          </div>

          <!-- Price + Rating -->
          <div class="flex flex-wrap items-center gap-4">

            <div class="bg-emerald-50 text-emerald-600 px-5 py-3 rounded-2xl font-bold text-xl">
              ₹<%= home.price %> / night
            </div>

            <div class="bg-yellow-50 text-yellow-600 px-5 py-3 rounded-2xl font-semibold text-lg">
              ⭐ <%= home.rating %> / 5
            </div>

          </div>

          <!-- Description -->
          <div class="border-t border-slate-200 pt-5">
            <h4 class="text-xl font-bold text-slate-800 mb-3">
              Description
            </h4>

            <p class="text-slate-600 leading-7">
              <%= home.description %>
            </p>
          </div>

          <!-- Amenities -->
          <div class="border-t border-slate-200 pt-5">
            <h4 class="text-xl font-bold text-slate-800 mb-3">
              Why You'll Love It
            </h4>

            <div class="grid grid-cols-2 gap-3 text-slate-600">

              <div class="bg-slate-100 px-4 py-3 rounded-xl">🏡 Comfortable Stay</div>
              <div class="bg-slate-100 px-4 py-3 rounded-xl">📶 Free WiFi</div>
              <div class="bg-slate-100 px-4 py-3 rounded-xl">🚗 Easy Parking</div>
              <div class="bg-slate-100 px-4 py-3 rounded-xl">🌟 Top Rated</div>

            </div>
          </div>

          <!-- Favourite Button -->
          <div class="pt-4">
           <%- include('../partials/favourite', { home: home }) %>
          </div>

        </div>

      </div>

    </section>

  </main>

</body>
</html>