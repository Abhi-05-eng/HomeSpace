<%- include('../partials/head') %>
</head>

<body class="bg-slate-100 min-h-screen">

  <%- include('../partials/nav') %>

  <main class="max-w-7xl mx-auto px-4 py-8">

    <!-- Page Card -->
    <section class="bg-white rounded-3xl shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="bg-gradient-to-r from-emerald-500 to-cyan-600 px-8 py-6 text-white">

        <div class="flex flex-col sm:flex-row items-center gap-4">

          <!-- Logo -->
          <div class="bg-white/15 backdrop-blur-md p-3 rounded-2xl border border-white/20 shadow-lg">
            <img 
              src="/images/logo.png"
              alt="HomeSpace Logo"
              class="w-14 h-14 object-contain"
            >
          </div>

          <!-- Title -->
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold">
              Hey Host! Here are your homes
            </h2>

            <p class="mt-2 text-sm text-white/90">
              Manage, edit and grow your premium listings on HomeSpace
            </p>
          </div>

        </div>

      </div>

      <!-- Homes Grid -->
      <div class="p-8">

        <% if (registeredHomes.length > 0) { %>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

            <% registeredHomes.forEach(home => { %>

              <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition duration-300">

                <!-- Image -->
                <img 
                  src="<%= home.photo %>" 
                  alt="<%= home.houseName %>" 
                  class="w-full h-56 object-cover"
                >

                <!-- Body -->
                <div class="p-5">

                  <!-- Name -->
                  <h3 class="text-xl font-bold text-slate-800 mb-2 truncate">
                    <%= home.houseName %>
                  </h3>

                  <!-- Location -->
                  <p class="text-slate-500 text-sm mb-3">
                    📍 <%= home.location %>
                  </p>

                  <!-- Price + Rating -->
                  <div class="flex items-center justify-between mb-5">

                    <span class="text-lg font-bold text-emerald-600">
                      ₹<%= home.price %> / night
                    </span>

                    <span class="flex items-center gap-1 text-yellow-500 font-semibold">
                      ⭐ <%= home.rating %>
                    </span>

                  </div>

                  <!-- Buttons -->
                  <div class="flex gap-3">

                    <a 
                      href="/host/add-home/<%= home._id %>?editing=true"
                      class="flex-1 text-center bg-cyan-500 hover:bg-cyan-600 text-white py-2.5 rounded-xl font-medium transition duration-300"
                    >
                      Edit
                    </a>

                    <form 
                      action="/host/delete-home/<%= home._id %>" 
                      method="POST"
                      class="flex-1"
                    >
                      <button 
                        type="submit"
                        class="w-full bg-red-500 hover:bg-red-600 text-white py-2.5 rounded-xl font-medium transition duration-300"
                      >
                        Delete
                      </button>
                    </form>

                  </div>

                </div>

              </div>

            <% }) %>

          </div>

        <% } else { %>

          <!-- Empty State -->
          <div class="text-center py-16">

            <img 
              src="/images/logo.png"
              class="w-20 h-20 mx-auto mb-4 opacity-70"
              alt="HomeSpace"
            >

            <h3 class="text-2xl font-bold text-slate-700 mb-2">
              No Homes Listed Yet
            </h3>

            <p class="text-slate-500 mb-6">
              Start hosting and add your first premium property.
            </p>

            <a 
              href="/host/add-home"
              class="inline-block bg-gradient-to-r from-emerald-500 to-cyan-600 text-white px-6 py-3 rounded-xl font-semibold shadow-lg hover:scale-105 transition duration-300"
            >
              Add New Home
            </a>

          </div>

        <% } %>

      </div>

    </section>

  </main>

</body>
</html>
