<%- include('../partials/head') %>
</head>

<body class="bg-slate-100 min-h-screen">

  <%- include('../partials/nav') %>
  <%- include('../partials/flash') %>

  <main class="max-w-4xl mx-auto px-4 py-8">

    <!-- Card -->
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="bg-gradient-to-r from-emerald-500 to-cyan-600 px-8 py-6 text-white">

        <!-- Header Top -->
        <div class="flex flex-col sm:flex-row items-center gap-4">

          <!-- Logo -->
          <div class="bg-white/15 backdrop-blur-md p-3 rounded-2xl border border-white/20 shadow-lg">
            <img 
              src="/images/logo.png" 
              alt="HomeSpace Logo"
              class="w-14 h-14 object-contain"
            >
          </div>

          <!-- Heading -->
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold">
              <%= editing ? "Edit Your Home" : "Register Your Home" %>
            </h1>

            <p class="mt-2 text-sm text-white/90">
              List your property professionally on HomeSpace
            </p>
          </div>

        </div>

      </div>

      <!-- Form -->
      <form 
        action="<%= editing ? '/host/edit-home' : '/host/add-home' %>" method="POST" enctype="multipart/form-data"
        class="p-8 grid grid-cols-1 md:grid-cols-2 gap-4"
      >

        <input type="hidden" name="id" value="<%= editing ? home._id : '' %>" />

        <!-- House Name -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            House Name
          </label>
          <input
            type="text"
            name="houseName"
            value="<%= editing ? home.houseName : '' %>"
            placeholder="Luxury Villa"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none"
          />
        </div>

        <!-- Price -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Price Per Night
          </label>
          <input
            type="text"
            name="price"
            value="<%= editing ? home.price : '' %>"
            placeholder="₹2500"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none"
          />
        </div>

        <!-- Location -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Location
          </label>
          <input
            type="text"
            name="location"
            value="<%= editing ? home.location : '' %>"
            placeholder="Goa, India"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none"
          />
        </div>

        <!-- Rating -->
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Rating
          </label>
          <input
            type="text"
            name="rating"
            value="<%= editing ? home.rating : '' %>"
            placeholder="4.8"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none"
          />
        </div>

        <!-- Photo  -->
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Photo 
          </label>
          <input
            type="file"
            name="photo"
            multiple
            accept="image/*"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none"
          />
        </div>

        <!-- Description -->
        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-gray-700 mb-2">
            Description
          </label>
          <textarea
            name="description"
            rows="5"
            placeholder="Describe your home..."
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none"
          ><%= editing ? home.description : '' %></textarea>
        </div>

        <!-- Submit -->
        <div class="md:col-span-2 pt-2">
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-emerald-500 to-cyan-600 text-white font-semibold py-3 rounded-xl hover:scale-[1.02] transition duration-300 shadow-lg"
          >
            <%= editing ? "Update Home" : "Add Home" %>
          </button>
        </div>

      </form>

    </div>

  </main>

</body>
</html>