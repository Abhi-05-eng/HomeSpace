<%- include('../partials/head') %>
</head>

<body class="bg-slate-100 min-h-screen">

<%- include('../partials/nav') %>
<%- include('../partials/flash') %>

<main class="max-w-7xl mx-auto px-4 py-8">

<section class="bg-white rounded-3xl shadow-2xl overflow-hidden">

<div class="bg-gradient-to-r from-indigo-600 to-cyan-600 text-white p-8">

<h2 class="text-4xl font-bold">
Booking Requests
</h2>

<p class="mt-2 text-white/90">
Guests who have booked your homes.
</p>

</div>

<!-- Analytics Dashboard -->

<div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-5 p-8 bg-slate-50">

  <div class="bg-white rounded-2xl shadow-md p-5 text-center border">
    <div class="text-3xl">📋</div>
    <h3 class="text-slate-500 mt-2 text-sm">Total Requests</h3>
    <p class="text-3xl font-bold mt-2">
      <%= totalRequests %>
    </p>
  </div>

  <div class="bg-yellow-50 rounded-2xl shadow-md p-5 text-center border border-yellow-200">
    <div class="text-3xl">🟡</div>
    <h3 class="text-yellow-700 mt-2 text-sm">Pending</h3>
    <p class="text-3xl font-bold mt-2 text-yellow-700">
      <%= pending %>
    </p>
  </div>

  <div class="bg-green-50 rounded-2xl shadow-md p-5 text-center border border-green-200">
    <div class="text-3xl">✅</div>
    <h3 class="text-green-700 mt-2 text-sm">Confirmed</h3>
    <p class="text-3xl font-bold mt-2 text-green-700">
      <%= confirmed %>
    </p>
  </div>

  <div class="bg-red-50 rounded-2xl shadow-md p-5 text-center border border-red-200">
    <div class="text-3xl">❌</div>
    <h3 class="text-red-700 mt-2 text-sm">Rejected</h3>
    <p class="text-3xl font-bold mt-2 text-red-700">
      <%= rejected %>
    </p>
  </div>

  <div class="bg-gray-100 rounded-2xl shadow-md p-5 text-center border">
    <div class="text-3xl">🚫</div>
    <h3 class="text-slate-700 mt-2 text-sm">Cancelled</h3>
    <p class="text-3xl font-bold mt-2">
      <%= cancelled %>
    </p>
  </div>

  <div class="bg-emerald-50 rounded-2xl shadow-md p-5 text-center border border-emerald-200">
    <div class="text-3xl">💰</div>
    <h3 class="text-emerald-700 mt-2 text-sm">Revenue</h3>
    <p class="text-2xl font-bold mt-2 text-emerald-700">
      ₹<%= expectedRevenue.toLocaleString("en-IN") %>
    </p>
  </div>

</div>

<% if(bookings.length === 0){ %>

<div class="text-center py-16">

<h2 class="text-3xl font-bold">
No Booking Requests
</h2>

<p class="text-slate-500 mt-3">
When guests book your homes, they will appear here.
</p>

</div>

<% }else{ %>

<div class="p-8 space-y-8">

<% bookings.forEach(booking=>{ %>

<div class="bg-slate-50 rounded-3xl shadow-lg overflow-hidden">

<div class="grid md:grid-cols-3">

<div>

<img
src="<%= booking.homeId.photo %>"
class="w-full h-72 object-cover">

</div>

<div class="md:col-span-2 p-8">

<div class="flex justify-between">

<div>

<h2 class="text-3xl font-bold">

<%= booking.homeId.houseName %>

</h2>

<p class="text-slate-500 mt-2">

📍 <%= booking.homeId.location %>

</p>

</div>

<% if (booking.status === "Pending") { %>

<span class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full font-semibold">
  Pending
</span>

<% } else if (booking.status === "Confirmed") { %>

<span class="bg-green-100 text-green-700 px-4 py-2 rounded-full font-semibold">
  Confirmed
</span>

<% } else if (booking.status === "Rejected") { %>

<span class="bg-red-100 text-red-700 px-4 py-2 rounded-full font-semibold">
  Rejected
</span>

<% } else { %>

<span class="bg-gray-100 text-gray-700 px-4 py-2 rounded-full font-semibold">
  Cancelled
</span>

<% } %>

</div>

<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-8">

  <!-- Guest -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      👤 Guest
    </h3>

    <p class="mt-2 font-medium">
      <%= booking.guestId.firstName %> <%= booking.guestId.lastName %>
    </p>

    <p class="text-sm text-slate-500 mt-1">
      <%= booking.guestId.email %>
    </p>

  </div>

  <!-- Check In -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      📅 Check In
    </h3>

    <p class="mt-2">
      <%= new Date(booking.checkIn).toLocaleDateString("en-IN") %>
    </p>

  </div>

  <!-- Check Out -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      📅 Check Out
    </h3>

    <p class="mt-2">
      <%= new Date(booking.checkOut).toLocaleDateString("en-IN") %>
    </p>

  </div>

  <!-- Guests -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      👥 Guests
    </h3>

    <p class="mt-2">
      <%= booking.guests %>
    </p>

  </div>

  <!-- Nights -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      🌙 Nights
    </h3>

    <p class="mt-2">
      <%= booking.nights %>
    </p>

  </div>

  <!-- Total -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      💰 Total Amount
    </h3>

    <p class="mt-2 text-xl font-bold text-emerald-600">
      ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
    </p>

  </div>

  <!-- Booking Date -->
  <div class="bg-white rounded-xl p-4 border">

    <h3 class="font-semibold text-slate-600">
      📝 Requested On
    </h3>

    <p class="mt-2">
      <%= new Date(booking.bookingDate).toLocaleDateString("en-IN") %>
    </p>

  </div>

</div>

<div class="mt-8 flex gap-4">

<% if (booking.status === "Pending") { %>

<div class="mt-8 flex gap-4">

  <form
    action="/bookings/<%= booking._id %>/accept?_method=PATCH"
    method="POST">

    <button
      class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-xl">
      Accept
    </button>

  </form>

  <form
    action="/bookings/<%= booking._id %>/reject?_method=PATCH"
    method="POST">

    <button
      class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-xl">
      Reject
    </button>

  </form>

</div>

<% } %>

</div>

</div>

</div>

</div>

<% }) %>

</div>

<% } %>

</section>

</main>

</body>

</html>